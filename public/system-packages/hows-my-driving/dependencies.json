[
  {
    "ID": "fill-archetype",
    "sources": [{ "类型": "resourcePicker", "模块ID": "pick-archetype" }],
    "targets": [
      { "类型": "module", "模块ID": "archetype-name" },
      { "类型": "module", "模块ID": "archetype-abilities" }
    ],
    "触发": { "类型": "resourceSelected", "来源模块ID": "pick-archetype" },
    "条件": { "类型": "always" },
    "动作": [
      {
        "类型": "fillText",
        "目标模块ID": "archetype-name",
        "写入方式": "替换",
        "内容": { "类型": "selectedResourceField", "字段": "名称" }
      },
      {
        "类型": "fillText",
        "目标模块ID": "archetype-abilities",
        "写入方式": "替换",
        "内容": {
          "类型": "selectedResourceTemplate",
          "格式": "**增益｜{{增益名称}}**\n{{增益}}\n\n**缺陷｜{{缺陷名称}}**\n{{缺陷}}"
        }
      }
    ]
  },
  {
