[
  {
    "ID": "fill-class-from-picker",
    "sources": [{ "类型": "resourcePicker", "模块ID": "pick-class" }],
    "targets": [
      { "类型": "module", "模块ID": "class-name" },
      { "类型": "module", "模块ID": "class-domains" },
      { "类型": "module", "模块ID": "class-evasion" },
      { "类型": "module", "模块ID": "class-hp" },
      { "类型": "module", "模块ID": "class-hope" },
      { "类型": "module", "模块ID": "class-feature" },
      { "类型": "module", "模块ID": "class-background-questions" }
    ],
    "触发": { "类型": "resourceSelected", "来源模块ID": "pick-class" },
    "条件": { "类型": "always" },
    "动作": [
      { "类型": "fillText", "目标模块ID": "class-name", "内容": { "类型": "selectedResourceField", "字段": "名称" } },
      { "类型": "fillText", "目标模块ID": "class-domains", "内容": { "类型": "selectedResourceField", "字段": "领域" } },
      { "类型": "fillText", "目标模块ID": "class-evasion", "内容": { "类型": "selectedResourceField", "字段": "初始闪避值" } },
      {
        "类型": "fillCountable",
        "目标模块ID": "class-hp",
        "当前值": { "类型": "selectedResourceField", "字段": "初始生命点" },
        "最大值": { "类型": "selectedResourceField", "字段": "初始生命点" }
      },
      { "类型": "fillText", "目标模块ID": "class-hope", "内容": { "类型": "selectedResourceField", "字段": "希望特性" } },
      { "类型": "fillText", "目标模块ID": "class-feature", "内容": { "类型": "selectedResourceField", "字段": "职业特性" } },
      { "类型": "fillText", "目标模块ID": "class-background-questions", "内容": { "类型": "selectedResourceField", "字段": "背景问题" } }
    ]
  },
  {
    "ID": "show-druid-helpers",
    "sources": [{ "类型": "resourcePicker", "模块ID": "pick-class" }],
    "targets": [
      { "类型": "page", "页面ID": "druid-shape-page" },
      { "类型": "module", "模块ID": "druid-shape-note" },
      { "类型": "module", "模块ID": "pick-subclass" }
    ],
    "触发": { "类型": "resourceSelected", "来源模块ID": "pick-class" },
    "条件": { "类型": "selectedResourceFieldEquals", "字段": "名称", "值": "德鲁伊" },
    "动作": [
      { "类型": "setVisibility", "目标类型": "page", "目标ID": "druid-shape-page", "显示": true },
      { "类型": "setVisibility", "目标类型": "module", "目标ID": "druid-shape-note", "显示": true },
      { "类型": "setResourceDefaultFilter", "目标模块ID": "pick-subclass", "字段": "主职", "值": ["德鲁伊"] }
    ]
  },
  {
    "ID": "hide-druid-helpers",
    "sources": [{ "类型": "resourcePicker", "模块ID": "pick-class" }],
    "targets": [
      { "类型": "page", "页面ID": "druid-shape-page" },
      { "类型": "module", "模块ID": "druid-shape-note" }
    ],
    "触发": { "类型": "resourceSelected", "来源模块ID": "pick-class" },
    "条件": { "类型": "selectedResourceFieldNotEquals", "字段": "名称", "值": "德鲁伊" },
    "动作": [
      { "类型": "setVisibility", "目标类型": "page", "目标ID": "druid-shape-page", "显示": false },
      { "类型": "setVisibility", "目标类型": "module", "目标ID": "druid-shape-note", "显示": false }
    ]
  },
  {
    "ID": "fill-subclass-from-picker",
    "sources": [{ "类型": "resourcePicker", "模块ID": "pick-subclass" }],
    "targets": [
      { "类型": "module", "模块ID": "subclass-name" },
      { "类型": "module", "模块ID": "subclass-spellcast" },
      { "类型": "module", "模块ID": "subclass-feature" }
    ],
    "触发": { "类型": "resourceSelected", "来源模块ID": "pick-subclass" },
    "条件": { "类型": "always" },
    "动作": [
      { "类型": "fillText", "目标模块ID": "subclass-name", "内容": { "类型": "selectedResourceField", "字段": "名称" } },
      { "类型": "fillText", "目标模块ID": "subclass-spellcast", "内容": { "类型": "selectedResourceField", "字段": "施法属性" } },
      { "类型": "fillText", "目标模块ID": "subclass-feature", "内容": { "类型": "selectedResourceField", "字段": "描述" } }
    ]
  },
  {
    "ID": "fill-domain-card-from-picker",
    "sources": [{ "类型": "resourcePicker", "模块ID": "pick-domain-card" }],
    "targets": [
      { "类型": "module", "模块ID": "domain-card-name" },
      { "类型": "module", "模块ID": "domain-card-summary" }
    ],
    "触发": { "类型": "resourceSelected", "来源模块ID": "pick-domain-card" },
    "条件": { "类型": "always" },
    "动作": [
      { "类型": "fillText", "目标模块ID": "domain-card-name", "内容": { "类型": "selectedResourceField", "字段": "名称" } },
      { "类型": "fillText", "目标模块ID": "domain-card-summary", "内容": { "类型": "selectedResourceField", "字段": "描述" } }
    ]
  },
  {
    "ID": "fill-domain-card-list-from-picker",
    "sources": [{ "类型": "resourcePicker", "模块ID": "pick-domain-cards" }],
    "targets": [{ "类型": "module", "模块ID": "domain-card-list" }],
    "触发": { "类型": "resourceSelected", "来源模块ID": "pick-domain-cards" },
    "条件": { "类型": "always" },
    "动作": [
      {
        "类型": "fillText",
        "目标模块ID": "domain-card-list",
        "内容": { "类型": "selectedResourceField", "字段": "名称", "分隔符": "、" }
      }
    ]
  },
  {
    "ID": "show-background-helper-from-checkbox",
    "sources": [{ "类型": "checkboxResource", "模块ID": "creation-toggles" }],
    "targets": [{ "类型": "module", "模块ID": "background-helper" }],
    "触发": { "类型": "checkboxChanged", "来源模块ID": "creation-toggles" },
    "条件": { "类型": "checkboxOptionChecked", "选项ID": "show-background-helper" },
    "动作": [
      {
        "类型": "fillText",
        "目标模块ID": "background-helper",
        "内容": "把职业背景问题复制到角色背景时，可以先回答其中一个问题，再改写成自己的经历。"
      },
      { "类型": "setVisibility", "目标类型": "module", "目标ID": "background-helper", "显示": true }
    ]
  },
  {
    "ID": "hide-background-helper-from-checkbox",
    "sources": [{ "类型": "checkboxResource", "模块ID": "creation-toggles" }],
    "targets": [{ "类型": "module", "模块ID": "background-helper" }],
    "触发": { "类型": "checkboxChanged", "来源模块ID": "creation-toggles" },
    "条件": { "类型": "checkboxOptionUnchecked", "选项ID": "show-background-helper" },
    "动作": [
      { "类型": "setVisibility", "目标类型": "module", "目标ID": "background-helper", "显示": false }
    ]
  }
]
