[
  {
    "ID": "fill-survivor-style",
    "sources": [{ "类型": "resourceComposer", "模块ID": "pick-survivor-style" }],
    "targets": [
      { "类型": "module", "模块ID": "survivor-style-name" },
      { "类型": "module", "模块ID": "survivor-style-features" }
    ],
    "触发": { "类型": "resourceSelected", "来源模块ID": "pick-survivor-style" },
    "条件": { "类型": "always" },
    "动作": [
      {
        "类型": "fillText",
        "目标模块ID": "survivor-style-name",
        "内容": { "类型": "selectedResourceTemplate", "格式": "{{第一风格}} / {{第二风格}}" }
      },
      {
        "类型": "fillText",
        "目标模块ID": "survivor-style-features",
        "内容": { "类型": "selectedResourceTemplate", "格式": "**{{第一特性名称}}**\n{{第一特性规则}}\n\n**{{第二特性名称}}**\n{{第二特性规则}}" }
      }
    ]
  }
]
