      "路径": "resources/classes.json"
    },
    {
      "ID": "subclasses",
      "名称": "子职",
      "路径": "resources/subclasses.json"
    },
    {
      "ID": "weapons",
      "名称": "武器",
      "路径": "resources/weapons.json"
    },
    {
      "ID": "armor",
      "名称": "护甲",
      "路径": "resources/armor.json"
    },
    {
      "ID": "loot",
      "名称": "物品与消耗品",
      "路径": "resources/loot.json"
    },
    {
      "ID": "domain-cards",
