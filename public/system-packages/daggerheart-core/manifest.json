      "名称": "松烟纸墨",
      "css": "skins/skin-KimiK3/skin.css",
      "推荐框架配色": "light",
      "layoutOverrides": {
        "shell": { "html": "skins/skin-KimiK3/shell.html" },
        "pages": [
          { "ID": "character-main", "html": "skins/skin-KimiK3/character-main.html" },
          { "ID": "character-story", "html": "skins/skin-KimiK3/character-story.html" }
        ]
      }
    },
    {
      "ID": "skin-black-hours",
      "名称": "黑时祷书",
      "css": "skins/skin-black-hours/skin.css",
      "推荐框架配色": "dark",
      "layoutOverrides": {
        "shell": { "html": "skins/skin-black-hours/shell.html" },
        "pages": [
          { "ID": "character-main", "html": "skins/skin-black-hours/character-main.html" }
        ]
      }
    }
  ],
  "defaultSkin": "skin-KimiK3",
  "pages": "pages.json",
  "shell": {
    "html": "layouts/shell.html",
    "css": "layouts/shell.css"
