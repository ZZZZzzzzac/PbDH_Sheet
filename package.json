{
  "name": "pbdh-sheet",
  "private": true,
  "version": "1.3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "npm run test:health && vitest run",
    "test:health": "node --test scripts/test-health.test.mjs && node scripts/test-health.mjs",
    "test:release": "node --test scripts/release-tools.test.mjs",
    "test:e2e": "playwright test",
    "check:release-version": "node scripts/release-tools.mjs check-tag",
    "verify:release-build": "node scripts/release-tools.mjs verify-build",
    "preview": "vite preview"
  },
  "dependencies": {
    "acorn": "^8.17.0",
    "dexie": "^4.4.4",
    "fflate": "^0.8.3",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-directive": "^4.0.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
