[
  {
    "ID": "fill-class-from-picker",
    "sources": [{ "类型": "resourcePicker", "模块ID": "pick-class" }],
    "targets": [
      { "类型": "module", "模块ID": "class-name" },
      { "类型": "module", "模块ID": "class-domains" },
      { "类型": "module", "模块ID": "class-evasion" },
      { "类型": "module", "模块ID": "class-hp" },
      { "类型": "module", "模块ID": "class-feature" },
      { "类型": "module", "模块ID": "class-background-questions" },
      { "类型": "module", "模块ID": "pick-subclass" }
    ],
    "触发": { "类型": "resourceSelected", "来源模块ID": "pick-class" },
    "条件": { "类型": "always" },
    "动作": [
      { "类型": "fillText", "目标模块ID": "class-name", "内容": { "类型": "selectedResourceField", "字段": "名称" } },
      { "类型": "fillText", "目标模块ID": "class-domains", "内容": { "类型": "selectedResourceField", "字段": "主题组合" } },
      { "类型": "fillText", "目标模块ID": "class-evasion", "内容": { "类型": "selectedResourceField", "字段": "初始闪避值" } },
      { "类型": "fillCountable", "目标模块ID": "class-hp", "当前值": { "类型": "selectedResourceField", "字段": "初始生命点" }, "最大值": { "类型": "selectedResourceField", "字段": "初始生命点" } },
      { "类型": "fillText", "目标模块ID": "class-feature", "内容": { "类型": "selectedResourceField", "字段": "职业特性" } },
      { "类型": "fillText", "目标模块ID": "class-background-questions", "内容": { "类型": "selectedResourceField", "字段": "背景问题" } },
      { "类型": "setResourceDefaultFilter", "目标模块ID": "pick-subclass", "字段": "主职", "值": { "类型": "selectedResourceField", "字段": "名称" } }
    ]
  },
  {
    "ID": "show-lantern-note",
    "sources": [{ "类型": "resourcePicker", "模块ID": "pick-class" }],
    "targets": [{ "类型": "module", "模块ID": "lantern-note" }],
    "触发": { "类型": "resourceSelected", "来源模块ID": "pick-class" },
    "条件": { "类型": "selectedResourceFieldEquals", "字段": "名称", "值": "守灯人" },
    "动作": [{ "类型": "setVisibility", "目标类型": "module", "目标ID": "lantern-note", "显示": true }]
  },
  {
    "ID": "hide-lantern-note",
    "sources": [{ "类型": "resourcePicker", "模块ID": "pick-class" }],
    "targets": [{ "类型": "module", "模块ID": "lantern-note" }],
    "触发": { "类型": "resourceSelected", "来源模块ID": "pick-class" },
    "条件": { "类型": "selectedResourceFieldNotEquals", "字段": "名称", "值": "守灯人" },
    "动作": [{ "类型": "setVisibility", "目标类型": "module", "目标ID": "lantern-note", "显示": false }]
  },
  {
    "ID": "fill-subclass-from-picker",
    "sources": [{ "类型": "resourcePicker", "模块ID": "pick-subclass" }],
    "targets": [{ "类型": "module", "模块ID": "subclass-name" }, { "类型": "module", "模块ID": "subclass-feature" }],
    "触发": { "类型": "resourceSelected", "来源模块ID": "pick-subclass" },
    "条件": { "类型": "always" },
    "动作": [
      { "类型": "fillText", "目标模块ID": "subclass-name", "内容": { "类型": "selectedResourceField", "字段": "名称" } },
      { "类型": "fillText", "目标模块ID": "subclass-feature", "内容": { "类型": "selectedResourceField", "字段": "描述" } }
    ]
  },
  {
    "ID": "fill-demo-card-from-picker",
    "sources": [{ "类型": "resourcePicker", "模块ID": "pick-card-single" }],
    "targets": [{ "类型": "module", "模块ID": "selected-card-name" }],
    "触发": { "类型": "resourceSelected", "来源模块ID": "pick-card-single" },
    "条件": { "类型": "always" },
    "动作": [{ "类型": "fillText", "目标模块ID": "selected-card-name", "内容": { "类型": "selectedResourceField", "字段": "名称" } }]
  },
  {
    "ID": "fill-demo-card-list-from-picker",
    "sources": [{ "类型": "resourcePicker", "模块ID": "pick-cards-multiple" }],
    "targets": [{ "类型": "module", "模块ID": "selected-card-list" }],
    "触发": { "类型": "resourceSelected", "来源模块ID": "pick-cards-multiple" },
    "条件": { "类型": "always" },
    "动作": [{ "类型": "fillText", "目标模块ID": "selected-card-list", "内容": { "类型": "selectedResourceField", "字段": "名称", "分隔符": "、" } }]
  },
  {
    "ID": "show-background-helper",
    "sources": [{ "类型": "checkboxResource", "模块ID": "creation-toggles" }],
    "targets": [{ "类型": "module", "模块ID": "background-helper" }],
    "触发": { "类型": "checkboxChanged", "来源模块ID": "creation-toggles" },
    "条件": { "类型": "checkboxOptionChecked", "选项ID": "show-background-helper" },
    "动作": [
      { "类型": "fillText", "目标模块ID": "background-helper", "内容": "Checkbox Dependency 已触发：这个 longText 同时被填入并显示。" },
      { "类型": "setVisibility", "目标类型": "module", "目标ID": "background-helper", "显示": true }
    ]
  },
  {
    "ID": "hide-background-helper",
    "sources": [{ "类型": "checkboxResource", "模块ID": "creation-toggles" }],
    "targets": [{ "类型": "module", "模块ID": "background-helper" }],
    "触发": { "类型": "checkboxChanged", "来源模块ID": "creation-toggles" },
    "条件": { "类型": "checkboxOptionUnchecked", "选项ID": "show-background-helper" },
    "动作": [{ "类型": "setVisibility", "目标类型": "module", "目标ID": "background-helper", "显示": false }]
  }
]
